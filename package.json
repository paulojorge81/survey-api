{
  "name": "survey-api",
  "version": "1.5.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/main/server.js",
    "debug": "nodemon -L --watch ./dist --inspect=0.0.0.0:9222 --nolazy ./dist/main/server.js",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev:up": "pnpm build && docker compose -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "lint": "eslint src --max-warnings=0",
    "test": "jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "jest --passWithNoTests",
    "test:unit": "pnpm test --watch -c jest-unit.config.js",
    "test:integration": "pnpm test --watch -c jest-integration.config.js",
    "test:staged": "pnpm test --findRelatedTests",
    "test:ci": "pnpm test --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "pnpm lint --fix",
      "pnpm test:staged"
    ]
  },
  "keywords": [],
  "author": "Paulo Jorge",
  "license": "ISC",
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shelf/jest-mongodb": "^6.0.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint": "^10.3.0",
    "eslint-config-love": "^153.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.6.0",
    "git-commit-msg-linter": "^5.0.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "mockdate": "^3.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "nodemon": "^3.1.14",
    "validator": "^13.15.35"
  },
  "engines": {
    "node": "24.x"
  }
}
