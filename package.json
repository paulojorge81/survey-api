    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint": "^10.2.0",
    "eslint-config-love": "^153.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.6.0",
    "git-commit-msg-linter": "^5.0.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
