{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "commonjs",
    "target": "ES2023",
    "sourceMap": true,
    "esModuleInterop": true,
    "allowJs": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@data/*": [
        "./data/*"
      ],
      "@domain/*": [
        "./domain/*"
      ],
      "@infra/*": [
        "./infra/*"
      ],
      "@main/*": [
        "./main/*"
      ],
      "@presentation/*": [
        "./presentation/*"
      ],
      "@validation/*": [
        "./validation/*"
      ]
    },
    "types": [
      "jest",
      "node"
    ]
  },
  "exclude": [],
  "include": [
    "src/**/*.ts"
  ]
}
